---
import '@fontsource/rajdhani/400.css';
import '@fontsource/rajdhani/500.css';
import '@fontsource/rajdhani/600.css';
import '@fontsource/rajdhani/700.css';
import '../styles/global.css';
import 'aos/dist/aos.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

const { title = 'Portfolio', navigation } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- Anti-flash: apply saved theme before first paint -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('portfolio-theme') || 'system';
        var resolved = saved === 'system'
          ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
          : saved;
        document.documentElement.classList.add(resolved);
      })();
    </script>
  </head>

  <body class="bg-[var(--p-base)] text-[var(--p-text)] transition-colors duration-300">
    <a class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 bg-[#5a95c1] text-[#202738] px-3 py-2 rounded" href="#home">
      Skip to content
    </a>

    <div class="sticky top-0 z-50 px-4 pt-3 pb-2" style="background: var(--p-header-gradient);">
      <div class="max-w-[900px] mx-auto flex items-center gap-3">
        <header class="min-w-0 flex-1">
          <nav
            class="w-full px-4 py-2 flex items-center justify-between gap-4 border"
            style="
              border-radius: 22px;
              border-color: var(--p-nav-border);
              background: var(--p-nav-bg);
              backdrop-filter: blur(10px);
              box-shadow: 0 10px 30px rgba(80,100,130,0.12), inset 0 1px 0 rgba(255,255,255,0.08);
            "
          >
            <div class="font-[Rajdhani] font-bold tracking-tight text-sm" style="color: var(--p-text);">
              {title}
            </div>
            <ul class="hidden md:flex items-center gap-2 ml-auto">
              {navigation?.map((item: { href: string; label: string }) => (
                <li class="flex items-center">
                  <a
                    href={item.href}
                    class="nav-link inline-flex items-center justify-center min-h-8 px-3 py-1.5 border text-[13px] leading-none font-bold font-[Rajdhani] focus:outline-none focus:ring-2 focus:ring-[var(--p-accent)]"
                    style="
                      border-radius: 14px;
                      background: var(--p-nav-pill-bg);
                      border-color: var(--p-nav-pill-border);
                      color: var(--p-text);
                      box-shadow: 0 2px 8px rgba(100,116,139,0.08);
                      transition: all 0.2s ease;
                    "
                    onmouseover="this.style.background='var(--p-nav-hover-bg, rgba(255,255,255,0.9))'; this.style.boxShadow='0 6px 14px rgba(100,116,139,0.12)'; this.style.transform='translateY(-1px)';"
                    onmouseout="this.style.background='var(--p-nav-pill-bg)'; this.style.boxShadow='0 2px 8px rgba(100,116,139,0.08)'; this.style.transform='none';"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </header>
        <div class="shrink-0">
          <ThemeToggle />
        </div>
      </div>
    </div>

    <main class="w-full min-w-[320px]">
      <slot />
    </main>

    <ScrollToTop />

    <script src="../assets/js/main.js"></script>
  </body>
</html>
