---
import "@fontsource/rajdhani/400.css";
import "@fontsource/rajdhani/500.css";
import "@fontsource/rajdhani/600.css";
import "@fontsource/rajdhani/700.css";
import "../styles/global.css";
import "aos/dist/aos.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import ScrollToTop from "../components/ScrollToTop.astro";

const { title = "Portfolio", navigation } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- Anti-flash: apply saved theme before first paint -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('portfolio-theme') || 'system';
        var resolved = saved === 'system'
          ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
          : saved;
        document.documentElement.classList.add(resolved);
      })();
    </script>
  </head>

  <body class="bg-[var(--p-base)] text-[var(--p-text)] transition-colors duration-300">
    <a class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 bg-[#5a95c1] text-[#202738] px-3 py-2 rounded" href="#home">
      Skip to content
    </a>

    <div class="sticky top-0 z-50 px-4 pt-3 pb-2" style="background: var(--p-header-gradient);">
      <div class="max-w-[900px] mx-auto flex flex-col lg:flex-row items-stretch lg:items-center gap-3">
        <header class="min-w-0 flex-1">
          <nav
            data-mobile-nav
            class="w-full px-4 py-3 lg:py-2 flex flex-col lg:flex-row lg:items-center justify-between gap-3 border"
            style="
              border-radius: 22px;
              border-color: var(--p-nav-border);
              background: var(--p-nav-bg);
              backdrop-filter: blur(10px);
              box-shadow: var(--p-nav-shell-shadow, 0 10px 30px rgba(80,100,130,0.12));
            "
          >
            <div class="flex items-center justify-between gap-3 lg:contents">
              <div class="font-[Rajdhani] font-bold tracking-[0.14em] text-sm uppercase shrink-0" style="color: var(--p-text);">
                {title}
              </div>
              <div class="flex items-center gap-2 shrink-0 lg:hidden">
                <ThemeToggle />
                <button
                  type="button"
                  class="mobile-menu-toggle inline-flex items-center justify-center rounded-[14px] border px-3 py-2 font-[Rajdhani] font-bold text-[12px] uppercase tracking-[0.14em]"
                  style="background: var(--p-nav-pill-bg); border-color: var(--p-nav-pill-border); color: var(--p-text); box-shadow: var(--p-nav-pill-shadow);"
                  aria-expanded="false"
                  aria-controls="mobile-nav-links"
                  data-mobile-nav-toggle
                >
                  Menu
                </button>
              </div>
            </div>
            <ul id="mobile-nav-links" class="nav-list hidden lg:flex lg:items-center gap-2 lg:ml-auto pb-1 lg:pb-0" data-mobile-nav-list>
              {navigation?.map((item: { href: string; label: string }) => (
                <li class="flex items-center">
                  <a
                    href={item.href}
                    class="nav-link inline-flex items-center justify-center min-h-8 px-3 py-1.5 border text-[13px] leading-none font-bold font-[Rajdhani] focus:outline-none focus:ring-2 focus:ring-[var(--p-accent)]"
                    style="
                      border-radius: 14px;
                      background: var(--p-nav-pill-bg);
                      border-color: var(--p-nav-pill-border);
                      color: var(--p-text);
                      box-shadow: var(--p-nav-pill-shadow, 0 2px 8px rgba(100,116,139,0.08));
                    "
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </header>
        <div class="shrink-0 hidden lg:block">
          <ThemeToggle />
        </div>
      </div>
    </div>

    <main class="w-full min-w-[320px]">
      <slot />
    </main>

    <ScrollToTop />

    <style>
      .nav-link {
        flex-shrink: 0;
        transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
      }

      .nav-list {
        scrollbar-width: none;
      }

      .nav-list::-webkit-scrollbar {
        display: none;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        background: var(--p-nav-hover-bg, rgba(255,255,255,0.9));
        border-color: var(--p-nav-pill-border);
        box-shadow: var(--p-nav-pill-hover-shadow, 0 6px 14px rgba(100,116,139,0.12));
        transform: translateY(-1px);
      }

      .mobile-menu-toggle {
        transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
      }

      .mobile-menu-toggle:hover,
      .mobile-menu-toggle:focus-visible {
        background: var(--p-nav-hover-bg, rgba(255,255,255,0.9));
        border-color: var(--p-nav-pill-border);
        box-shadow: var(--p-nav-pill-hover-shadow, 0 6px 14px rgba(100,116,139,0.12));
        transform: translateY(-1px);
      }

      @media (max-width: 1023px) {
        .nav-list.is-open {
          display: flex;
          flex-direction: column;
          align-items: stretch;
          width: 100%;
          padding-top: 0.25rem;
        }

        .nav-list.is-open li {
          width: 100%;
        }

        .nav-list.is-open .nav-link {
          width: 100%;
          justify-content: center;
          min-height: 2.5rem;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const nav = document.querySelector('[data-mobile-nav]');
        const toggle = nav?.querySelector('[data-mobile-nav-toggle]');
        const list = nav?.querySelector('[data-mobile-nav-list]');

        if (!(toggle instanceof HTMLButtonElement) || !(list instanceof HTMLElement)) return;

        const closeMenu = () => {
          list.classList.remove('is-open');
          list.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
        };

        const syncDesktopState = () => {
          if (window.innerWidth >= 1024) {
            list.classList.remove('hidden');
            list.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
            return;
          }

          if (!list.classList.contains('is-open')) {
            list.classList.add('hidden');
          }
        };

        toggle.addEventListener('click', () => {
          const willOpen = !list.classList.contains('is-open');
          list.classList.toggle('is-open', willOpen);
          list.classList.toggle('hidden', !willOpen);
          toggle.setAttribute('aria-expanded', String(willOpen));
        });

        list.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (window.innerWidth < 1024) closeMenu();
          });
        });

        window.addEventListener('resize', syncDesktopState);
        syncDesktopState();
      })();
    </script>

    <script src="../assets/js/main.js"></script>
  </body>
</html>
