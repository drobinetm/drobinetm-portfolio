---
const { footer } = Astro.props;
---
<footer class="w-full min-h-[54px] flex bg-[var(--p-footer-bg)] px-4 py-3">
  <div class="w-full max-w-[240px] mx-auto flex flex-wrap items-center justify-center gap-x-1 gap-y-0.5 text-center">
    <div class="flex items-center justify-center font-[Rajdhani] font-bold text-[10px] leading-[26px] whitespace-nowrap" style="color: var(--p-text);">
      {footer.designedByLabel}
    </div>
    <div class="flex items-center justify-center font-[Rajdhani] font-bold text-[10px] leading-[26px] whitespace-nowrap" style="color: var(--p-accent);">
      {footer.name}
    </div>
  </div>
</footer>
