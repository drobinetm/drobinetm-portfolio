---
<button id="scroll-to-top" aria-label="Scroll to top" title="Scroll to top">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"/>
  </svg>
</button>

<style>
  #scroll-to-top {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 100;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--p-nav-border, rgba(90,149,193,0.25));
    background: var(--p-nav-bg, rgba(7,58,105,0.15));
    color: var(--p-text-subtle, #b5b6b8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition:
      opacity 280ms ease,
      transform 280ms ease,
      background 200ms ease,
      border-color 200ms ease,
      color 200ms ease;
  }

  #scroll-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #scroll-to-top:hover {
    background: var(--p-navy-28, #073a6947);
    border-color: var(--p-accent, #5a95c1);
    color: var(--p-text, #ffffff);
  }

  #scroll-to-top:active {
    background: var(--p-accent, #5a95c1);
    color: var(--p-text-on-accent, #181725);
    transform: scale(0.93);
  }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('scroll-to-top');
    if (!btn) return;

    window.addEventListener('scroll', function () {
      btn.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });

    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>
