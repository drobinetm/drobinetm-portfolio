---
import IconInfo from "../IconInfo.astro";
import FrontendIcon from "../icons/FrontendIcon.astro";
import BackendIcon from "../icons/BackendIcon.astro";
import DevOpsIcon from "../icons/DevOpsIcon.astro";
import { withBase } from "../../utils/withBase";

const { skills } = Astro.props;
---
<style>
    .skill-card {
        background: var(--p-skill-card-bg);
        border: 1px solid var(--p-skill-card-border);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .skill-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--p-card-shadow-hover), var(--p-card-inset-highlight);
    }

    .skill-card-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--p-border-pill);
    }

    .skill-icon {
        color: var(--p-text-subtle);
        flex-shrink: 0;
    }

    .skill-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--p-text);
        margin: 0;
    }

    .skill-items {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .skill-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .skill-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .skill-name {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--p-text-subtle);
    }

    .skill-percentage {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--p-text);
    }

    .skill-bar-bg {
        position: absolute;
        inset: 0;
        background: var(--p-surface-alt);
        border-radius: 0.25rem;
    }

    .skill-percentage {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--p-text);
    }

    .skill-bar-container {
        position: relative;
        width: 100%;
        height: 0.5rem;
        border-radius: 0.25rem;
        overflow: hidden;
    }

    .skill-bar-bg {
        position: absolute;
        inset: 0;
        background: var(--p-surface-alt);
        border-radius: 0.25rem;
    }

    .skill-bar-fill {
        position: absolute;
        inset: 0;
        background: var(--p-accent-deep);
        border-radius: 0.25rem;
        transition: width 0.6s ease;
    }

    .skills-cta:hover {
        background: linear-gradient(180deg, #2d6f98 0%, #1f5f8f 100%) !important;
        border-color: var(--p-nav-active-border) !important;
        box-shadow: var(--p-nav-pill-hover-shadow), inset 0 1px 0 rgba(255,255,255,0.18) !important;
    }

    @media (max-width: 768px) {
        .skill-card {
            padding: 1.25rem;
        }

        .skill-title {
            font-size: 1.125rem;
        }
    }
</style>
<section id="skills" data-aos="fade-up" data-aos-delay="300" class="w-full flex flex-col gap-8 py-10 px-4" style="background: var(--p-navy-20);">
  <div class="max-w-[1155px] mx-auto w-full">
    <div class="flex justify-center">
      <div class="flex items-center gap-2 px-6 py-2 rounded-[50px] border" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
        <IconInfo class="w-4 h-4" style="color: var(--p-text);" />
        <span class="font-[Rajdhani] font-bold text-base leading-[26px]" style="color: var(--p-text);">
          {skills.badge}
        </span>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {skills.sections.map((section: { id: string; title: string; icon: string; items: { name: string; percentage: number }[] }) => (
        <div class="skill-card">
          <div class="skill-card-header">
            <div class="skill-icon">
              {section.icon === 'frontend' && <FrontendIcon />}
              {section.icon === 'backend' && <BackendIcon />}
              {section.icon === 'devops' && <DevOpsIcon />}
            </div>
            <h3 class="skill-title">{section.title}</h3>
          </div>

          <div class="skill-items">
            {section.items.map((skill) => (
              <div class="skill-item">
                <div class="skill-info">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-percentage">{skill.percentage}%</span>
                </div>
                <div class="skill-bar-container">
                  <div class="skill-bar-bg"></div>
                  <div class="skill-bar-fill" style={`width: ${(skill.percentage / 100) * 100}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="flex justify-center mt-8">
      <a
        href={withBase(skills.ctaHref ?? '/cv/CURRICULUM VITAE EN CURRENT.pdf')}
        download
        class="skills-cta inline-flex h-auto px-4 py-1.5 rounded-lg border font-[Rajdhani] font-bold text-sm leading-[26px] focus:outline-none focus:ring-2 focus:ring-[var(--p-accent)] transition-[background-color,border-color,box-shadow,color,transform] duration-200 hover:-translate-y-0.5"
        style="background: var(--p-nav-active-bg); border-color: var(--p-nav-active-border); color: var(--p-text-on-accent); box-shadow: var(--p-nav-active-shadow), inset 0 1px 0 rgba(255,255,255,0.18);"
      >
        {skills.ctaLabel}
      </a>
    </div>
  </div>
</section>
