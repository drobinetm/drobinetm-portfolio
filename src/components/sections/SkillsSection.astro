---
import IconInfo from '../IconInfo.astro';
import FrontendIcon from '../icons/FrontendIcon.astro';
import BackendIcon from '../icons/BackendIcon.astro';
import DevOpsIcon from '../icons/DevOpsIcon.astro';
import { withBase } from '../../utils/withBase';

const { skills } = Astro.props;
---
<style>
    .skill-card {
        background: var(--p-skill-card-bg);
        border: 1px solid var(--p-skill-card-border);
        border-radius: 1rem;
        padding: 1.5rem;
        transition: all 0.3s ease;
    }

    .skill-card-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(0, 217, 255, 0.1);
    }

    .skill-icon {
        color: var(--p-text-subtle);
        flex-shrink: 0;
    }

    .skill-title {
        font-family: 'Rajdhani', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--p-text);
        margin: 0;
    }

    .skill-items {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .skill-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .skill-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .skill-name {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--p-text-subtle);
    }

    .skill-percentage {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--p-text);
    }

    .skill-bar-bg {
        position: absolute;
        inset: 0;
        background: var(--p-surface-alt);
        border-radius: 0.25rem;
    }

    .skill-percentage {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--p-text);
    }

    .skill-bar-container {
        position: relative;
        width: 100%;
        height: 0.5rem;
        border-radius: 0.25rem;
        overflow: hidden;
    }

    .skill-bar-bg {
        position: absolute;
        inset: 0;
        background: var(--p-surface-alt);
        border-radius: 0.25rem;
    }

    .skill-bar-fill {
        position: absolute;
        inset: 0;
        background: #0c4a80;
        border-radius: 0.25rem;
        transition: width 0.6s ease;
    }

    @media (max-width: 768px) {
        .skill-card {
            padding: 1.25rem;
        }

        .skill-title {
            font-size: 1.125rem;
        }
    }
</style>
<section id="skills" data-aos="fade-in" data-aos-delay="300" class="w-full flex flex-col gap-8 bg-[#073a6933] py-10 px-4">
  <div class="max-w-[1155px] mx-auto w-full">
    <div class="flex justify-center">
      <div class="flex items-center gap-2 px-6 py-2 rounded-[50px] border" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
        <IconInfo class="w-4 h-4" style="color: var(--p-text);" />
        <span class="font-[Rajdhani] font-bold text-base leading-[26px]" style="color: var(--p-text);">
          {skills.badge}
        </span>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {skills.sections.map((section: { id: string; title: string; icon: string; items: { name: string; percentage: number }[] }) => (
        <div class="skill-card">
          <div class="skill-card-header">
            <div class="skill-icon">
              {section.icon === 'frontend' && <FrontendIcon />}
              {section.icon === 'backend' && <BackendIcon />}
              {section.icon === 'devops' && <DevOpsIcon />}
            </div>
            <h3 class="skill-title">{section.title}</h3>
          </div>

          <div class="skill-items">
            {section.items.map((skill) => (
              <div class="skill-item">
                <div class="skill-info">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-percentage">{skill.percentage}%</span>
                </div>
                <div class="skill-bar-container">
                  <div class="skill-bar-bg"></div>
                  <div class="skill-bar-fill" style={`width: ${(skill.percentage / 100) * 100}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="flex justify-center mt-8">
      <a
        href={withBase(skills.ctaHref ?? '/cv/CURRICULUM VITAE EN CURRENT.pdf')}
        download
        class="inline-flex h-auto px-4 py-1.5 bg-[#5a95c1] rounded-lg border border-[#ffffff26] shadow-[inset_0px_0px_6px_3px_#ffffff40] hover:bg-[#5a95c1]/90 font-[Rajdhani] font-bold text-[#202738] text-sm leading-[26px] focus:outline-none focus:ring-2 focus:ring-[#5a95c1]"
      >
        {skills.ctaLabel}
      </a>
    </div>
  </div>
</section>
