---
import IconInfo from '../IconInfo.astro';
import { withBase } from '../../utils/withBase';
const { projects } = Astro.props;
---
<section id="projects" data-aos="fade-in" data-aos-delay="300" class="relative w-full flex flex-col bg-[#073a694c] py-[34px]">
  <div class="flex justify-center">
    <div class="flex items-center gap-2 rounded-[50px] border px-[37px] h-11" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
      <IconInfo class="w-4 h-4" style="color: var(--p-text);" />
      <span class="font-[Rajdhani] font-bold text-base leading-[26px]" style="color: var(--p-text);">
        {projects.badge}
      </span>
    </div>
  </div>

  <div class="flex justify-center mt-12 px-4">
    <article class="prose prose-lg max-w-[801px] font-[Rajdhani] font-normal text-base text-justify leading-[26px]" style="color: var(--p-text-muted);">
      {projects.intro}
    </article>
  </div>

  <div class="flex justify-center mt-9">
    <div class="flex flex-wrap justify-center gap-[6px]" data-project-filters>
      {projects.filters.map((option: { value: string; label: string }) => (
        <button
          type="button"
          class="filter-pill flex items-center gap-[7px] px-3.5 py-2 bg-[#1817252e] rounded-[50px] border border-[#ffffff26] h-auto cursor-pointer"
          data-value={option.value}
        >
          <span class="filter-pill__inner flex items-center justify-center px-2.5 py-2 h-[26px] rounded-[40px] bg-[#073a69]">
            <span class="font-[Rajdhani] font-bold text-[10px] leading-[26px] whitespace-nowrap text-[#b5b6b8]">
              {option.label}
            </span>
          </span>
        </button>
      ))}
    </div>
  </div>

  <div class="flex justify-center mt-9 px-4">
    <div class="w-full max-w-[860px]" data-project-grid>
      <div class="projects-grid">
        {projects.images.map((image: { className: string; title: string; alt: string; src: string; href?: string; tags?: string[]; imageClassName?: string; filteredClassName?: string }) => (
          <div
            class="project-card"
            data-tags={(image.tags ?? []).join(',')}
          >
            {image.href ? (
              <a
                class="project-card-link"
                href={image.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={image.alt}
              >
                <div class="project-card__image-wrap">
                  <img
                    class="project-card__image"
                    alt={image.alt}
                    src={withBase(image.src)}
                    loading="lazy"
                  />
                  <div class="project-card__overlay"></div>
                  <div class="project-card__hover-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </div>
                </div>
                <div class="project-card__footer">
                  <span class="project-card__title">{image.title}</span>
                  <span class="project-card__arrow">↗</span>
                </div>
              </a>
            ) : (
              <div>
                <div class="project-card__image-wrap">
                  <img
                    class="project-card__image"
                    alt={image.alt}
                    src={withBase(image.src)}
                    loading="lazy"
                  />
                  <div class="project-card__overlay"></div>
                </div>
                <div class="project-card__footer">
                  <span class="project-card__title">{image.title}</span>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 16px;
    }

    .project-card {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.07);
      background: rgba(7, 20, 40, 0.35);
      transition: transform 260ms ease, box-shadow 260ms ease, opacity 260ms ease;
    }

    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    }

    .project-card.hidden {
      display: none;
    }

    .project-card-link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .project-card__image-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
      overflow: hidden;
      border-radius: 0 0 50% 50% / 0 0 28px 28px;
    }

    .project-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 320ms ease;
    }

    .project-card:hover .project-card__image {
      transform: scale(1.04);
    }

    .project-card__overlay {
      position: absolute;
      inset: 0;
      background: var(--p-project-overlay-bg);
      opacity: 0;
      transition: opacity 260ms ease;
    }

    .project-card:hover .project-card__overlay {
      opacity: 1;
    }

    .project-card__hover-icon {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #ffffff;
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .project-card:hover .project-card__hover-icon {
      opacity: 1;
      transform: scale(1);
    }

    .project-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 14px 12px;
      gap: 6px;
    }

    .project-card__title {
      font-family: "Rajdhani", system-ui, sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--p-text);
      line-height: 1.2;
    }

    .project-card__arrow {
      font-size: 0.85rem;
      color: var(--p-text-muted);
      opacity: 0.6;
      flex-shrink: 0;
      transition: opacity 200ms ease, transform 200ms ease;
    }

    .project-card:hover .project-card__arrow {
      opacity: 1;
      transform: translate(2px, -2px);
    }
  </style>

  <script is:inline>
    const root = document.currentScript.closest('section');
    const filtersEl = root?.querySelector('[data-project-filters]');
    const gridEl = root?.querySelector('[data-project-grid]');

    const buttons = Array.from(filtersEl.querySelectorAll('button[data-value]'));
    const cards = Array.from(gridEl.querySelectorAll('.project-card[data-tags]'));

    let selected = 'all';

    function getVisibleCards() {
      if (selected === 'all') return cards;
      return cards.filter((card) => {
        const tags = (card.dataset.tags || '').split(',').map((s) => s.trim()).filter(Boolean);
        return tags.includes(selected);
      });
    }

    function paintButtons() {
      for (const btn of buttons) {
        const value = btn.dataset.value;
        const on = value === selected;
        const inner = btn.querySelector('.filter-pill__inner');
        const label = btn.querySelector('.filter-pill__inner span');
        inner?.classList.toggle('bg-[#5a95c1]', on);
        inner?.classList.toggle('bg-[#073a69]', !on);
        label?.classList.toggle('text-[#181725]', on);
        label?.classList.toggle('text-[#b5b6b8]', !on);
        btn.setAttribute('aria-pressed', String(on));
      }
    }

    function paintCards() {
      const visible = getVisibleCards();
      cards.forEach((card) => {
        const show = visible.includes(card);
        card.classList.toggle('hidden', !show);
      });
    }

    paintButtons();
    paintCards();

    filtersEl.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-value]');
      if (!btn) return;
      selected = btn.dataset.value || 'all';
      paintButtons();
      paintCards();
    });
  </script>
</section>
