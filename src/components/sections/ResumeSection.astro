---
import IconInfo from "../IconInfo.astro";
import { withBase } from "../../utils/withBase";
const { resume } = Astro.props;
---
<style>
  .timeline {
    list-style: none;
    padding: 40px 0 40px 20px;
    position: relative;
  }

  .timeline:before {
    top: 0;
    bottom: 0;
    position: absolute;
    content: " ";
    width: 1px;
    background-color: #eeeeee;
    left: 92%;
    margin-left: 0px;
  }

  .timeline .timeline-important {
    background-color: var(--p-resume-important-bg) !important;
  }

  .timeline .timeline-important .timeline-title,
  .timeline .timeline-important .timeline-body,
  .timeline .timeline-important .timeline-body ul,
  .timeline .timeline-important .timeline-body a {
    color: var(--p-resume-on-image-text);
  }

  .timeline .timeline-important .timeline-place {
    color: var(--p-resume-on-image-text-muted);
  }

  .timeline .timeline-important:before {
    border-left-color: var(--p-resume-important-bg) !important;
    border-right-color: var(--p-resume-important-bg) !important;
  }

  .timeline .timeline-important:after {
    border-left-color: var(--p-resume-important-arrow-border) !important;
    border-right-color: var(--p-resume-important-arrow-border) !important;
  }

  .timeline > li {
    margin-bottom: 20px;
    position: relative;
  }

  .timeline > li:before,
  .timeline > li:after {
    content: " ";
    display: table;
  }

  .timeline > li:after {
    clear: both;
  }

  .timeline > li > .timeline-panel {
    width: 88%;
    float: left;
    border: 1px solid var(--p-resume-panel-border);
    border-radius: 10px;
    padding: 20px;
    position: relative;
    -webkit-box-shadow: var(--p-card-shadow);
    box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);
    background-color: var(--p-resume-panel-bg);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .timeline > li > .timeline-panel:hover {
    transform: translateY(-3px);
    box-shadow: var(--p-card-shadow-hover), var(--p-card-inset-highlight);
  }

  .timeline > li > .timeline-panel:before {
    position: absolute;
    top: 26px;
    right: -15px;
    display: inline-block;
    border-top: 15px solid transparent;
    border-left: 15px solid var(--p-resume-panel-arrow);
    border-right: 0 solid var(--p-resume-panel-arrow);
    border-bottom: 15px solid transparent;
    content: " ";
  }

  .timeline > li > .timeline-panel:after {
    position: absolute;
    top: 27px;
    right: -14px;
    display: inline-block;
    border-top: 14px solid transparent;
    border-left: 14px solid var(--p-resume-panel-arrow-inner);
    border-right: 0 solid var(--p-resume-panel-arrow-inner);
    border-bottom: 14px solid transparent;
    content: " ";
  }

  .timeline > li > .timeline-badge {
    color: var(--p-text);
    width: 14px;
    height: 14px;
    line-height: 50px;
    font-size: 1.4em;
    text-align: center;
    position: absolute;
    top: 35px;
    left: 96%;
    margin-left: -28px;
    background-color: var(--p-accent-deep);
    z-index: 100;
    border-radius: 50%;
    border: 1px solid var(--p-accent-light);
  }

  .timeline-title {
    margin-top: 0;
    color: inherit;
    font-size: 16px;
  }

  .timeline-place {
    margin-top: 0;
    color: var(--p-accent-light);
    font-size: 14px;
  }

  .timeline-body {
    margin-top: 0;
  }

  .timeline-body > p,
  .timeline-body > ul {
    margin-bottom: 0;
  }

  .timeline-body > p + p {
    margin-top: 5px;
  }

  .timeline-body a {
    font-size: 12px;
    background: var(--p-resume-button-bg);
    border: 1px solid var(--p-resume-button-border);
    border-radius: 50px;
    color: var(--p-text);
    padding: 8px;
    transition: 0.3s;
    cursor: pointer;
    width: 30%;
    display: block;
    text-align: center;
    text-decoration: none;
  }

  .timeline-body a:hover {
    background: var(--p-resume-button-hover-bg);
    border-color: var(--p-resume-button-hover-border);
  }

  .resume-hero-summary {
    position: absolute;
    top: 300px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 760px;
    padding-inline: 1rem;
  }

  @media (min-width: 640px) {
    .resume-hero-summary {
      top: 445px;
    }
  }

  @media (max-width: 767px) {
    .timeline {
      padding: 20px 0 24px 0;
    }

    .timeline > li {
      margin-bottom: 1.5rem;
      padding-top: 0;
    }

    .timeline:before {
      left: 20px;
    }

    .timeline > li > .timeline-panel {
      width: calc(100% - 54px);
      margin-right: 12px;
      margin-top: 0;
      padding: 16px;
    }

    .timeline > li > .timeline-badge {
      left: 13px;
      margin-left: 0;
      top: 1rem;
    }

    .timeline > li > .timeline-panel {
      float: right;
    }

    .timeline > li > .timeline-panel:before {
      border-left-width: 0;
      border-right-width: 15px;
      top: 8px;
      left: -15px;
      right: auto;
    }

    .timeline > li > .timeline-panel:after {
      border-left-width: 0;
      border-right-width: 14px;
      top: 9px;
      left: -14px;
      right: auto;
    }

    .timeline-place {
      line-height: 1.45;
    }

    .timeline-body a {
      width: 100%;
      max-width: 220px;
    }
  }

  @media (max-width: 1023px) {
    .resume-hero-summary {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      max-width: 100%;
      margin: -6rem auto 2rem;
      padding-inline: 0;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .resume-hero-summary {
      margin-top: -1.5rem;
    }
  }

  @media (max-width: 767px) {
    .resume-hero-media {
      height: 240px;
      margin-bottom: 0;
      border-radius: 14px;
    }

    .resume-hero-media-bottom {
      height: 120px;
    }

    .resume-hero-summary {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      margin: 1rem 0 1.5rem;
      padding-inline: 0;
    }

    .resume-card {
      min-height: auto;
    }

    .resume-card-title {
      white-space: normal;
      text-align: center;
      line-height: 1.2;
    }

    .resume-intro {
      padding-inline: 1rem;
      text-align: left;
      line-height: 1.7;
    }

    .resume-columns {
      padding-inline: 0;
      gap: 1rem;
    }
  }
</style>
<section id="resume" data-aos="fade-up" data-aos-delay="300" class="relative w-full rounded-[5px] overflow-hidden py-8 px-4" style="background: var(--p-resume-section-bg);">
  <div class="relative w-full max-w-[1155px] mx-auto">
    <div class="resume-hero-media relative w-full h-[520px] sm:h-[777px] rounded-[10px] overflow-hidden border mb-11" style="border-color: var(--p-accent-light); box-shadow: var(--p-card-shadow);">
      <img class="absolute top-0 left-0 w-full h-full object-cover" alt="Resume background" src={withBase(resume.backgroundImage)} loading="lazy" />
      <div class="absolute top-0 left-0 w-full h-full" style="background: var(--p-resume-overlay-top);" />
      <div class="resume-hero-media-bottom absolute bottom-0 left-0 w-full h-[356px]" style="background: var(--p-resume-overlay-bottom);" />
    </div>
    <div class="resume-hero-summary">
      <div class="rounded-[5px] overflow-hidden border" style="background: var(--p-resume-hero-card-bg); border-color: var(--p-resume-hero-card-border); box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);">
        <div class="flex flex-col gap-5 pt-7 pb-7">
          <div class="flex justify-center">
            <div class="h-11 gap-[7px] rounded-[50px] border px-6 flex items-center" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
              <IconInfo class="w-4 h-4" />
              <span class="font-[Rajdhani] font-bold text-base leading-[26px]" style="color: var(--p-text);">
                {resume.badge}
              </span>
            </div>
          </div>

          <article class="resume-intro prose prose-lg max-w-[801px] px-7 sm:px-12 font-[Rajdhani] font-normal text-base text-justify leading-[26px]" style="color: var(--p-resume-on-image-text-muted);">
            {resume.intro}
          </article>
        </div>
      </div>
    </div>
    <div class="resume-columns flex flex-col lg:flex-row gap-[29px] justify-center px-4">
      {resume.sections.map((section: { id: string; title: string, items: [] }) => (
        <div id={section.id} class="resume-card w-full lg:w-[530px] min-h-[420px] rounded-[5px] overflow-hidden border" style="background: var(--p-resume-card-bg); border-color: var(--p-resume-card-border); box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);">
          <div class="pt-6 flex justify-center">
            <div class="h-11 gap-2 rounded-[50px] border px-[25px] flex items-center" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
              <IconInfo class="w-4 h-4" />
              <span class="resume-card-title font-[Rajdhani] font-bold text-base leading-[26px] whitespace-nowrap" style="color: var(--p-text);">
                {section.title}
              </span>
            </div>
          </div>

          <ul class="timeline">
            {section.items.map((item: { title: string; date: string; place: string; url?: string; tasks?: string[]; customClass?: string }) => (
              <li>
                <div class="timeline-badge"></div>
                <div class={"timeline-panel " + item.customClass || ""}>
                  <div class="timeline-heading">
                    <h4 class="timeline-title">{item.title}</h4>
                    <p class="timeline-place">
                      <span style="color: var(--p-accent-link);">{item.date}</span> • {item.place}
                    </p>
                  </div>
                  <div class="timeline-body">
                    {item.tasks && item.tasks.length > 0 && (
                      <ul class="list-disc list-inside space-y-1 text-sm" style="color: var(--p-text-muted);">
                        {item.tasks.map((task: string) => (
                          <li>{task}</li>
                        ))}
                      </ul>
                    )}
                    {item.url && item.url !== '#' && (
                      <a href={item.url} target="_blank" rel="noopener noreferrer" class="mt-3">
                        View Certificate →
                      </a>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
