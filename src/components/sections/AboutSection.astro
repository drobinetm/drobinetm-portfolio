---
import IconInfo from '../IconInfo.astro';
import { withBase } from '../../utils/withBase';
import 'aos/dist/aos.css';
const { about } = Astro.props;
---
<style>
  .about-shell {
    background: linear-gradient(315deg, rgba(98,155,182,0.22) 0%, rgba(214,235,243,0.36) 100%);
    border-color: rgba(68,127,152,0.2);
    box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);
  }

  .about-image {
    border-color: rgba(98,155,182,0.4);
    box-shadow: var(--p-card-shadow), var(--p-card-inset-highlight);
  }

  .about-image-overlay {
    background: linear-gradient(180deg, rgba(68,127,152,0.16) 0%, rgba(20,50,70,0.32) 100%);
  }

  .about-status {
    background: rgba(248,251,253,0.66);
    border-color: rgba(98,155,182,0.2);
    box-shadow: var(--p-nav-pill-shadow), inset 0 1px 0 rgba(255,255,255,0.78);
  }

  .about-hire-link {
    background: var(--p-nav-active-bg);
    color: var(--p-text-on-accent);
    box-shadow: var(--p-nav-active-shadow), inset 0 1px 0 rgba(255,255,255,0.16);
    transition: background 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .about-hire-link:hover {
    background: linear-gradient(180deg, #2d6f98 0%, #1f5f8f 100%);
    transform: translateY(-1px);
    box-shadow: var(--p-nav-pill-hover-shadow), inset 0 1px 0 rgba(255,255,255,0.16);
  }

  @media (max-width: 768px) {
    .about-status {
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }

    .about-image-overlay {
      max-width: 100%;
    }
  }
</style>

<section id="about" data-aos="fade-in" data-aos-delay="300" class="px-4 py-8 bg-[var(--p-navy-28)]">
  <div class="max-w-[1155px] mx-auto">
    <div class="about-shell relative w-full rounded-[5px] overflow-hidden border">
      <div class="p-7 flex flex-col lg:flex-row gap-8">
        <div class="flex-1 flex flex-col gap-6">
          <div class="w-fit gap-[9px] h-11 flex items-center rounded-[50px] border px-4" style="background: var(--p-section-badge-bg); border-color: var(--p-section-badge-border);">
            <IconInfo class="w-4 h-4" style="color: var(--p-text);" />
            <span class="font-[Rajdhani] font-bold text-base leading-[26px] whitespace-nowrap" style="color: var(--p-text);">
              {about.badge}
            </span>
          </div>

          <div class="prose prose-lg font-[Rajdhani] font-normal text-base text-justify leading-[26px] whitespace-pre-line" style="color: var(--p-text-muted);">
            {about.text}
          </div>

          <div class="about-status w-[247px] gap-[7px] px-3.5 py-2 rounded-[50px] border flex items-center mt-auto">
            <a
              href="#contact"
              class="about-hire-link flex flex-col w-[68px] items-center justify-center p-2.5 h-[26px] rounded-[40px] focus:outline-none focus:ring-2 focus:ring-[var(--p-accent)]"
            >
              <span class="font-[Rajdhani] font-bold text-[10px] leading-[26px] whitespace-nowrap" style="color: var(--p-text-on-accent);">
                {about.hireCtaLabel}
              </span>
            </a>

            <span class="font-[Rajdhani] font-bold text-xs text-center whitespace-nowrap" style="color: var(--p-accent);">
              {about.availabilityText}
            </span>
          </div>
        </div>

        <div class="flex-shrink-0 relative">
          <img
            class="about-image w-full max-w-[353px] h-auto border rounded-[10px] object-cover"
            alt="About image"
            src={withBase(about.image)}
            loading="lazy"
          />
          <div class="about-image-overlay absolute inset-0 rounded-[10px] max-w-[353px] pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>
