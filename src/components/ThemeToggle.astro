---
// ThemeToggle.astro — Light / Dark / System theme switcher
---

<div class="theme-toggle" role="group" aria-label="Theme selector">
  <button data-theme="light"  class="theme-btn" aria-label="Light theme" title="Light">
    <!-- Sun icon -->
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1"  x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <span>Light</span>
  </button>

  <button data-theme="dark" class="theme-btn" aria-label="Dark theme" title="Dark">
    <!-- Moon icon -->
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <span>Dark</span>
  </button>

  <button data-theme="system" class="theme-btn" aria-label="System theme" title="System">
    <!-- Monitor icon -->
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
    <span>System</span>
  </button>
</div>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border-radius: 9999px;
    border: 1px solid var(--p-nav-border, rgba(90,149,193,0.25));
    background: var(--p-nav-pill-bg, rgba(7,58,105,0.15));
    backdrop-filter: blur(8px);
  }

  .theme-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 9px;
    border-radius: 9999px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--p-text-subtle, #b5b6b8);
    font-family: "Rajdhani", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .theme-btn:hover {
    background: var(--p-navy-28, #073a6947);
    border-color: var(--p-accent, #5a95c1);
    color: var(--p-text, #ffffff);
  }

  .theme-btn:focus-visible {
    outline: 2px solid var(--p-accent, #5a95c1);
    outline-offset: 2px;
  }

  .theme-btn.active {
    background: var(--p-accent, #5a95c1);
    border-color: var(--p-accent, #5a95c1);
    color: var(--p-text-on-accent, #181725);
  }

  /* Hide labels on very small screens, keep icons */
  @media (max-width: 480px) {
    .theme-btn span {
      display: none;
    }
    .theme-btn {
      padding: 5px 7px;
    }
  }
</style>

<script>
  (function () {
    const STORAGE_KEY = 'portfolio-theme';

    function getSystemTheme(): 'light' | 'dark' {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(theme: 'light' | 'dark' | 'system') {
      const resolved = theme === 'system' ? getSystemTheme() : theme;
      const html = document.documentElement;
      html.classList.remove('light', 'dark');
      html.classList.add(resolved);
    }

    function animateThemeChange(theme: 'light' | 'dark' | 'system') {
      const doc = document as Document & {
        startViewTransition?: (callback: () => void) => { finished: Promise<void> };
      };

      if (doc.startViewTransition) {
        doc.startViewTransition(() => {
          applyTheme(theme);
        });
        return;
      }

      const html = document.documentElement;
      html.classList.add('theme-is-changing');
      applyTheme(theme);
      window.setTimeout(() => {
        html.classList.remove('theme-is-changing');
      }, 520);
    }

    function setActive(theme: 'light' | 'dark' | 'system') {
      document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.theme === theme);
        btn.setAttribute('aria-pressed', String(btn.dataset.theme === theme));
      });
    }

    function init() {
      const saved = (localStorage.getItem(STORAGE_KEY) as 'light' | 'dark' | 'system') ?? 'system';
      applyTheme(saved);
      setActive(saved);

      document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const theme = btn.dataset.theme as 'light' | 'dark' | 'system';
          localStorage.setItem(STORAGE_KEY, theme);
          animateThemeChange(theme);
          setActive(theme);
        });
      });

      // React to OS preference changes when theme is "system"
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        const current = (localStorage.getItem(STORAGE_KEY) as string) ?? 'system';
        if (current === 'system') applyTheme('system');
      });
    }

    // Run after DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
